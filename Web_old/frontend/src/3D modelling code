<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>GNSS Terrain — Hectare Survey Viewer</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<style>
  :root{
    --bg:#0b0f14; --bg2:#0f151d; --panel:rgba(16,22,30,0.86); --line:#1d2733;
    --ink:#e6edf3; --dim:#8b9bab; --faint:#566472;
    --accent:#5ad1c5; --accent2:#e2b049; --warn:#e2725b;
    --mono:ui-monospace,"SF Mono","Roboto Mono",Menlo,Consolas,monospace;
    --sans:system-ui,-apple-system,"Segoe UI",sans-serif;
  }
  *{box-sizing:border-box}
  html,body{margin:0;height:100%;overflow:hidden;background:
    radial-gradient(1200px 800px at 70% -10%, #13202b 0%, var(--bg) 55%) fixed;
    color:var(--ink);font-family:var(--sans);-webkit-font-smoothing:antialiased}
  #app{position:fixed;inset:0}
  canvas{display:block;touch-action:none}

  /* ---- left console ---- */
  .console{position:absolute;top:14px;left:14px;width:320px;max-width:calc(100vw - 28px);
    background:var(--panel);backdrop-filter:blur(10px);border:1px solid var(--line);
    border-radius:14px;padding:14px 14px 12px;z-index:10;
    box-shadow:0 18px 50px rgba(0,0,0,.5)}
  .brand{display:flex;align-items:baseline;gap:8px;margin-bottom:2px}
  .brand b{font-size:13px;letter-spacing:.14em;text-transform:uppercase;font-weight:700}
  .brand span{font-family:var(--mono);font-size:10.5px;color:var(--accent);letter-spacing:.06em}
  .sub{font-family:var(--mono);font-size:10.5px;color:var(--dim);margin-bottom:12px}
  textarea{width:100%;height:104px;resize:vertical;background:#0a0e13;color:#cfe3df;
    border:1px solid var(--line);border-radius:9px;padding:9px;font-family:var(--mono);
    font-size:10.5px;line-height:1.45;outline:none}
  textarea:focus{border-color:#2a3a49}
  textarea::placeholder{color:#465562}
  .row{display:flex;gap:8px;margin-top:9px}
  button{flex:1;cursor:pointer;border:1px solid var(--line);background:#121a23;color:var(--ink);
    font-family:var(--sans);font-size:12px;font-weight:600;padding:9px 10px;border-radius:9px;
    transition:.15s;letter-spacing:.01em}
  button:hover{border-color:#33485a;background:#16212c}
  button.primary{background:linear-gradient(180deg,#1d6f67,#155a53);border-color:#2a8f84;color:#eafffb}
  button.primary:hover{background:linear-gradient(180deg,#23827a,#19655d)}
  .note{margin-top:9px;font-family:var(--mono);font-size:10px;color:var(--dim);min-height:14px}
  .note.warn{color:var(--warn)}

  /* ---- live feed ---- */
  .live{margin-top:10px;display:flex;gap:7px;align-items:center}
  .live input{flex:1;min-width:0;background:#0a0e13;color:#cfe3df;border:1px solid var(--line);
    border-radius:8px;padding:8px 9px;font-family:var(--mono);font-size:10.5px;outline:none}
  .live input:focus{border-color:#2a3a49}
  .live button{flex:none;width:auto;padding:8px 12px}
  .dot{width:8px;height:8px;border-radius:50%;background:#3a4654;flex:none;
    box-shadow:0 0 0 0 rgba(90,209,197,.5);transition:.2s}
  .dot.on{background:var(--accent);animation:pulse 1.6s infinite}
  .dot.err{background:var(--warn)}
  @keyframes pulse{0%{box-shadow:0 0 0 0 rgba(90,209,197,.5)}70%{box-shadow:0 0 0 7px rgba(90,209,197,0)}100%{box-shadow:0 0 0 0 rgba(90,209,197,0)}}

  /* ---- stats ---- */
  .stats{margin-top:12px;border-top:1px dashed var(--line);padding-top:11px;
    display:grid;grid-template-columns:1fr 1fr;gap:8px 10px}
  .stat .k{font-family:var(--mono);font-size:9px;letter-spacing:.1em;text-transform:uppercase;color:var(--dim)}
  .stat .v{font-family:var(--mono);font-size:14px;font-weight:600;margin-top:1px}
  .stat .v small{font-size:9.5px;color:var(--dim);font-weight:400;margin-left:2px}

  /* ---- controls ---- */
  .controls{border-top:1px dashed var(--line);margin-top:11px;padding-top:11px;
    display:flex;flex-direction:column;gap:9px}
  .ctl{display:flex;align-items:center;gap:10px}
  .ctl label{font-family:var(--mono);font-size:10px;color:var(--dim);width:88px;flex:none;
    letter-spacing:.04em}
  .ctl input[type=range]{flex:1;accent-color:var(--accent);height:3px}
  .ctl .val{font-family:var(--mono);font-size:10.5px;color:var(--accent);width:42px;text-align:right}
  .toggles{display:flex;flex-wrap:wrap;gap:7px;margin-top:1px}
  .chip{font-family:var(--mono);font-size:10px;padding:5px 9px;border:1px solid var(--line);
    border-radius:20px;cursor:pointer;color:var(--dim);user-select:none;transition:.15s}
  .chip.on{color:#0b0f14;background:var(--accent);border-color:var(--accent);font-weight:700}
  .chip.on.amber{background:var(--accent2);border-color:var(--accent2)}

  /* ---- legend (elevation ramp) ---- */
  .legend{position:absolute;right:14px;bottom:14px;z-index:10;background:var(--panel);
    backdrop-filter:blur(10px);border:1px solid var(--line);border-radius:12px;padding:11px 12px;
    width:150px;box-shadow:0 14px 40px rgba(0,0,0,.45)}
  .legend .t{font-family:var(--mono);font-size:9px;letter-spacing:.12em;text-transform:uppercase;
    color:var(--dim);margin-bottom:7px}
  .ramp{height:11px;border-radius:6px;border:1px solid #00000055}
  .legend .ends{display:flex;justify-content:space-between;font-family:var(--mono);font-size:10px;
    color:var(--ink);margin-top:5px}

  /* ---- compass ---- */
  .compass{position:absolute;right:14px;top:14px;z-index:10;width:78px;height:78px}
  .compass svg{display:block;filter:drop-shadow(0 6px 16px rgba(0,0,0,.5))}
  .azlabel{position:absolute;left:0;right:0;bottom:-17px;text-align:center;font-family:var(--mono);
    font-size:10px;color:var(--accent)}

  .hint{position:absolute;left:50%;bottom:14px;transform:translateX(-50%);z-index:9;
    font-family:var(--mono);font-size:10.5px;color:var(--dim);background:var(--panel);
    border:1px solid var(--line);border-radius:20px;padding:6px 14px;backdrop-filter:blur(8px);
    white-space:nowrap}

  @media (max-width:560px){
    .console{width:calc(100vw - 28px)}
    .legend{display:none}
    .hint{display:none}
  }
</style>
</head>
<body>
<div id="app"></div>

<div class="console">
  <div class="brand"><b>GNSS&nbsp;Terrain</b><span>Z-UP · v1</span></div>
  <div class="sub">Paste NMEA · GGA gives altitude · 1&nbsp;Hz field log</div>
  <textarea id="nmea" spellcheck="false" placeholder="$GPGGA,121106.00,4425.6080,N,02606.1500,E,1,08,0.9,082.4,M,45.0,M,,*5C
$GPGGA,121107.00,4425.6082,N,02606.1539,E,1,08,0.9,082.6,M,45.0,M,,*..."></textarea>
  <div class="row">
    <button class="primary" id="render">Render terrain</button>
    <button id="sample">Load sample</button>
  </div>
  <div class="live">
    <span class="dot" id="dot"></span>
    <input id="wsurl" value="ws://localhost:8080" spellcheck="false">
    <button id="connect">Connect</button>
  </div>
  <div class="note" id="note">Awaiting points — load a sample, or connect to the C++ bridge.</div>

  <div class="stats" id="stats" style="display:none">
    <div class="stat"><div class="k">Points</div><div class="v" id="s-pts">—</div></div>
    <div class="stat"><div class="k">Area covered</div><div class="v" id="s-area">—</div></div>
    <div class="stat"><div class="k">Elevation min</div><div class="v" id="s-emin">—</div></div>
    <div class="stat"><div class="k">Elevation max</div><div class="v" id="s-emax">—</div></div>
    <div class="stat"><div class="k">Relief</div><div class="v" id="s-rel">—</div></div>
    <div class="stat"><div class="k">Path length</div><div class="v" id="s-dist">—</div></div>
    <div class="stat"><div class="k">Duration</div><div class="v" id="s-dur">—</div></div>
    <div class="stat"><div class="k">Avg speed</div><div class="v" id="s-spd">—</div></div>
  </div>

  <div class="controls" id="ctrls" style="display:none">
    <div class="ctl"><label>Vert. exagg.</label>
      <input type="range" id="exag" min="1" max="8" step="0.5" value="2.5">
      <div class="val" id="exag-v">2.5×</div></div>
    <div class="ctl"><label>Contour int.</label>
      <input type="range" id="cint" min="0.5" max="10" step="0.5" value="2">
      <div class="val" id="cint-v">2 m</div></div>
    <div class="toggles">
      <div class="chip on" data-t="surface">Surface</div>
      <div class="chip on" data-t="contours">Contours</div>
      <div class="chip" data-t="wire">Wireframe</div>
      <div class="chip" data-t="points">Points</div>
      <div class="chip amber" data-t="spin">Auto-rotate</div>
    </div>
  </div>
</div>

<div class="compass">
  <svg width="78" height="78" viewBox="0 0 78 78">
    <circle cx="39" cy="39" r="34" fill="rgba(16,22,30,.86)" stroke="#1d2733"/>
    <g id="rose">
      <polygon points="39,10 44,39 39,33 34,39" fill="#e2725b"/>
      <polygon points="39,68 34,39 39,45 44,39" fill="#566472"/>
      <text x="39" y="22" text-anchor="middle" fill="#e6edf3" font-size="9"
        font-family="ui-monospace,monospace" font-weight="700">N</text>
    </g>
    <circle cx="39" cy="39" r="2" fill="#5ad1c5"/>
  </svg>
  <div class="azlabel" id="az">0°</div>
</div>

<div class="legend">
  <div class="t">Elevation (m MSL)</div>
  <div class="ramp" id="ramp"></div>
  <div class="ends"><span id="l-lo">—</span><span id="l-hi">—</span></div>
</div>

<div class="hint">Drag&nbsp;·&nbsp;rotate&nbsp;about&nbsp;Z&nbsp;&nbsp;|&nbsp;&nbsp;Scroll&nbsp;·&nbsp;zoom&nbsp;&nbsp;|&nbsp;&nbsp;Right-drag&nbsp;·&nbsp;pan</div>

<script>
// ============================ NMEA PARSING ============================
function parseCoord(v, hemi){
  if(!v) return null;
  const f = parseFloat(v); if(!isFinite(f)) return null;
  const deg = Math.floor(f/100);
  const min = f - deg*100;
  let dec = deg + min/60;
  if(hemi==='S' || hemi==='W') dec = -dec;
  return dec;
}
function parseTime(t){ // hhmmss.ss -> seconds of day
  if(!t || t.length<6) return null;
  const h=+t.slice(0,2), m=+t.slice(2,4), s=parseFloat(t.slice(4));
  if(![h,m,s].every(isFinite)) return null;
  return h*3600 + m*60 + s;
}
function parseNMEA(text){
  const pts=[]; let lines=0, spdSum=0, spdN=0;
  for(let raw of text.split(/\r?\n/)){
    raw = raw.trim(); if(!raw.startsWith('$')) continue;
    const body = raw.split('*')[0];
    const f = body.split(',');
    const type = f[0].slice(3); // strip talker (GP/GN/GL...)
    if(type==='GGA'){
      lines++;
      const lat=parseCoord(f[2],f[3]), lon=parseCoord(f[4],f[5]);
      const alt=parseFloat(f[9]); const fix=+f[6];
      if(lat!=null && lon!=null && isFinite(alt) && fix>0){
        pts.push({lat,lon,alt,t:parseTime(f[1])});
      }
    } else if(type==='RMC'){
      const kn=parseFloat(f[7]);
      if(isFinite(kn)){ spdSum+=kn*0.514444; spdN++; }
    }
  }
  return {pts, lines, rmcSpeed: spdN? spdSum/spdN : null};
}

// ============================ GEO -> LOCAL XYZ =======================
function toLocal(pts){
  let la=0,lo=0; for(const p of pts){la+=p.lat;lo+=p.lon;}
  const lat0=la/pts.length, lon0=lo/pts.length;
  const mPerLat=110540, mPerLon=111320*Math.cos(lat0*Math.PI/180);
  // dedupe near-identical XY (avoids degenerate triangles)
  const seen=new Map(), out=[];
  for(const p of pts){
    const x=(p.lon-lon0)*mPerLon, y=(p.lat-lat0)*mPerLat;
    const key=Math.round(x*20)+'_'+Math.round(y*20);
    if(seen.has(key)) continue; seen.set(key,1);
    out.push({x, y, z:p.alt, t:p.t});
  }
  return {nodes:out, lat0, lon0};
}

// ============================ DELAUNAY (Bowyer–Watson) ===============
function circum(a,b,c){
  const ax=a.x,ay=a.y,bx=b.x,by=b.y,cx=c.x,cy=c.y;
  const d=2*(ax*(by-cy)+bx*(cy-ay)+cx*(ay-by));
  if(Math.abs(d)<1e-12) return {x:0,y:0,r2:Infinity};
  const a2=ax*ax+ay*ay, b2=bx*bx+by*by, c2=cx*cx+cy*cy;
  const ux=(a2*(by-cy)+b2*(cy-ay)+c2*(ay-by))/d;
  const uy=(a2*(cx-bx)+b2*(ax-cx)+c2*(bx-ax))/d;
  return {x:ux, y:uy, r2:(ax-ux)**2+(ay-uy)**2};
}
function mkTri(a,b,c){ return {a,b,c, cc:circum(a,b,c)}; }
function sameEdge(e,g){ return (e[0]===g[0]&&e[1]===g[1])||(e[0]===g[1]&&e[1]===g[0]); }
function triangulate(nodes){
  const pts = nodes.map((n,i)=>({x:n.x, y:n.y, i}));
  if(pts.length<3) return [];
  let minX=Infinity,minY=Infinity,maxX=-Infinity,maxY=-Infinity;
  for(const p of pts){minX=Math.min(minX,p.x);minY=Math.min(minY,p.y);maxX=Math.max(maxX,p.x);maxY=Math.max(maxY,p.y);}
  const dmax=Math.max(maxX-minX,maxY-minY)||1, mx=(minX+maxX)/2, my=(minY+maxY)/2;
  const s0={x:mx-20*dmax,y:my-dmax,i:-1}, s1={x:mx,y:my+20*dmax,i:-2}, s2={x:mx+20*dmax,y:my-dmax,i:-3};
  let tris=[mkTri(s0,s1,s2)];
  for(const p of pts){
    const bad=[], keep=[];
    for(const t of tris){
      if((p.x-t.cc.x)**2+(p.y-t.cc.y)**2 <= t.cc.r2+1e-9){
        bad.push([t.a,t.b],[t.b,t.c],[t.c,t.a]);
      } else keep.push(t);
    }
    const bound=[];
    for(let i=0;i<bad.length;i++){
      let shared=false;
      for(let j=0;j<bad.length;j++){ if(i!==j && sameEdge(bad[i],bad[j])){shared=true;break;} }
      if(!shared) bound.push(bad[i]);
    }
    tris=keep;
    for(const e of bound) tris.push(mkTri(e[0],e[1],p));
  }
  const out=[];
  for(const t of tris){ if(t.a.i<0||t.b.i<0||t.c.i<0) continue; out.push([t.a.i,t.b.i,t.c.i]); }
  return out;
}

// ============================ HYPSOMETRIC COLOR RAMP ================
const STOPS=[[0,[31,77,122]],[0.15,[46,139,110]],[0.4,[143,191,90]],
            [0.6,[232,210,122]],[0.8,[201,138,75]],[1,[244,241,234]]];
function ramp(t){
  t=Math.max(0,Math.min(1,t));
  for(let i=0;i<STOPS.length-1;i++){
    const [a,ca]=STOPS[i],[b,cb]=STOPS[i+1];
    if(t>=a&&t<=b){const u=(t-a)/(b-a||1);
      return [ca[0]+(cb[0]-ca[0])*u, ca[1]+(cb[1]-ca[1])*u, ca[2]+(cb[2]-ca[2])*u];}
  }
  return STOPS[STOPS.length-1][1];
}

// ============================ THREE SETUP ===========================
const app=document.getElementById('app');
const scene=new THREE.Scene();
scene.fog=new THREE.FogExp2(0x0b0f14, 0.0016);
const camera=new THREE.PerspectiveCamera(52, innerWidth/innerHeight, 0.1, 100000);
camera.up.set(0,0,1); // Z is up
const renderer=new THREE.WebGLRenderer({antialias:true, alpha:true});
renderer.setPixelRatio(Math.min(devicePixelRatio,2));
renderer.setSize(innerWidth,innerHeight);
app.appendChild(renderer.domElement);

scene.add(new THREE.HemisphereLight(0xbcd6e8, 0x202830, 0.75));
const sun=new THREE.DirectionalLight(0xfff2dc, 1.05); sun.position.set(-1,-0.6,1.4); scene.add(sun);
const fill=new THREE.DirectionalLight(0x9fb4c7, 0.35); fill.position.set(1,0.8,0.5); scene.add(fill);

const world=new THREE.Group(); scene.add(world);
let meshObj=null, wireObj=null, contourObj=null, pointObj=null, grid=null, axes=null;
const flags={surface:true, contours:true, wire:false, points:false, spin:false};
let exag=2.5, contourInt=2, range={min:0,max:1};

// ---- orbit state (spherical, Z-up) ----
const orbit={target:new THREE.Vector3(), radius:200, theta:-Math.PI*0.75, phi:1.0};
function applyCam(){
  const sp=Math.sin(orbit.phi), x=orbit.radius*sp*Math.cos(orbit.theta),
        y=orbit.radius*sp*Math.sin(orbit.theta), z=orbit.radius*Math.cos(orbit.phi);
  camera.position.set(orbit.target.x+x, orbit.target.y+y, orbit.target.z+z);
  camera.lookAt(orbit.target);
}

// ============================ BUILD TERRAIN =========================
function clearWorld(){
  for(const o of [meshObj,wireObj,contourObj,pointObj,grid,axes]){
    if(o){world.remove(o); o.geometry&&o.geometry.dispose(); o.material&&o.material.dispose&&o.material.dispose();}
  }
  meshObj=wireObj=contourObj=pointObj=grid=axes=null;
}
function buildContours(verts, idx, cx, cy, minZ){
  const seg=[]; const lift=(range.max-range.min)*0.012*exag+0.05;
  let lvl=Math.ceil(range.min/contourInt)*contourInt;
  for(; lvl<range.max; lvl+=contourInt){
    for(let t=0;t<idx.length;t+=3){
      const a=idx[t],b=idx[t+1],c=idx[t+2];
      const P=[verts[a],verts[b],verts[c]];
      const cross=[];
      for(let e=0;e<3;e++){
        const p=P[e], q=P[(e+1)%3];
        if((p.z-lvl)*(q.z-lvl)<0){
          const u=(lvl-p.z)/(q.z-p.z);
          cross.push([p.x+(q.x-p.x)*u, p.y+(q.y-p.y)*u]);
        }
      }
      if(cross.length===2){
        const z=(lvl-minZ)*exag+lift;
        seg.push(cross[0][0]-cx, cross[0][1]-cy, z, cross[1][0]-cx, cross[1][1]-cy, z);
      }
    }
  }
  const g=new THREE.BufferGeometry();
  g.setAttribute('position', new THREE.Float32BufferAttribute(seg,3));
  return new THREE.LineSegments(g, new THREE.LineBasicMaterial({color:0x10161d, transparent:true, opacity:0.55}));
}
function buildTerrain(nodes, keepView){
  clearWorld();
  const idx=triangulate(nodes);
  if(idx.length===0){ note('Need at least 3 valid GGA fixes with altitude.', true); return false; }

  let minX=Infinity,maxX=-Infinity,minY=Infinity,maxY=-Infinity,minZ=Infinity,maxZ=-Infinity;
  for(const n of nodes){minX=Math.min(minX,n.x);maxX=Math.max(maxX,n.x);
    minY=Math.min(minY,n.y);maxY=Math.max(maxY,n.y);minZ=Math.min(minZ,n.z);maxZ=Math.max(maxZ,n.z);}
  const cx=(minX+maxX)/2, cy=(minY+maxY)/2;
  range={min:minZ, max:maxZ}; const span=(maxZ-minZ)||1;

  const pos=[], col=[];
  for(const n of nodes){
    pos.push(n.x-cx, n.y-cy, (n.z-minZ)*exag);
    const c=ramp((n.z-minZ)/span); col.push(c[0]/255,c[1]/255,c[2]/255);
  }
  const flat=[]; for(const tr of idx) flat.push(tr[0],tr[1],tr[2]);
  const geo=new THREE.BufferGeometry();
  geo.setAttribute('position', new THREE.Float32BufferAttribute(pos,3));
  geo.setAttribute('color', new THREE.Float32BufferAttribute(col,3));
  geo.setIndex(flat); geo.computeVertexNormals();

  meshObj=new THREE.Mesh(geo, new THREE.MeshStandardMaterial({
    vertexColors:true, roughness:0.92, metalness:0.0, side:THREE.DoubleSide,
    flatShading:false}));

  wireObj=new THREE.LineSegments(new THREE.WireframeGeometry(geo),
    new THREE.LineBasicMaterial({color:0x5ad1c5, transparent:true, opacity:0.16}));
  wireObj.visible=flags.wire;

  contourObj=buildContours(nodes, flat, cx, cy, minZ); contourObj.visible=flags.contours;

  const pg=new THREE.BufferGeometry();
  pg.setAttribute('position', new THREE.Float32BufferAttribute(pos,3));
  pg.setAttribute('color', new THREE.Float32BufferAttribute(col,3));
  pointObj=new THREE.Points(pg, new THREE.PointsMaterial({size:1.4, vertexColors:true,
    sizeAttenuation:true})); pointObj.visible=flags.points;

  const extent=Math.max(maxX-minX, maxY-minY, 10);
  grid=new THREE.GridHelper(Math.ceil(extent*1.4/10)*10, Math.ceil(extent*1.4/10),
    0x223040, 0x16202a); grid.rotation.x=Math.PI/2; grid.material.transparent=true; grid.material.opacity=0.5;
  axes=new THREE.AxesHelper(extent*0.18);

  world.add(meshObj, wireObj, contourObj, pointObj, grid, axes);
  meshObj.visible=flags.surface;

  if(!keepView){
    orbit.target.set(0,0,span*exag*0.4);
    orbit.radius=extent*1.5; orbit.theta=-Math.PI*0.75; orbit.phi=1.0;
  }
  applyCam();
  return true;
}

// ============================ STATS =================================
function fmtDur(s){ if(s==null) return '—';
  const m=Math.floor(s/60), ss=Math.round(s%60); return m+':'+String(ss).padStart(2,'0'); }
function updateStats(pts, nodes, parsed){
  let minZ=Infinity,maxZ=-Infinity; for(const n of nodes){minZ=Math.min(minZ,n.z);maxZ=Math.max(maxZ,n.z);}
  // path length (3D) & duration over original ordered fixes
  let dist=0; const mPerLat=110540;
  for(let i=1;i<pts.length;i++){
    const a=pts[i-1], b=pts[i];
    const dy=(b.lat-a.lat)*mPerLat;
    const dx=(b.lon-a.lon)*111320*Math.cos(a.lat*Math.PI/180);
    const dz=(b.alt-a.alt);
    dist+=Math.sqrt(dx*dx+dy*dy+dz*dz);
  }
  let dur=null;
  const ts=pts.map(p=>p.t).filter(v=>v!=null);
  if(ts.length>1) dur=ts[ts.length-1]-ts[0];
  let spd=parsed.rmcSpeed; if(spd==null && dur>0) spd=dist/dur;
  // area via triangulation
  const idx=triangulate(nodes); let area=0;
  for(const tr of idx){ const a=nodes[tr[0]],b=nodes[tr[1]],c=nodes[tr[2]];
    area+=Math.abs((b.x-a.x)*(c.y-a.y)-(c.x-a.x)*(b.y-a.y))/2; }

  const $=id=>document.getElementById(id);
  $('s-pts').innerHTML = nodes.length+' <small>/ '+parsed.lines+' GGA</small>';
  $('s-area').innerHTML = area>=10000 ? (area/10000).toFixed(2)+' <small>ha</small>'
                                      : Math.round(area)+' <small>m²</small>';
  $('s-emin').innerHTML = minZ.toFixed(1)+' <small>m</small>';
  $('s-emax').innerHTML = maxZ.toFixed(1)+' <small>m</small>';
  $('s-rel').innerHTML  = (maxZ-minZ).toFixed(1)+' <small>m</small>';
  $('s-dist').innerHTML = dist>=1000 ? (dist/1000).toFixed(2)+' <small>km</small>'
                                     : Math.round(dist)+' <small>m</small>';
  $('s-dur').innerHTML  = fmtDur(dur);
  $('s-spd').innerHTML  = spd!=null ? spd.toFixed(2)+' <small>m/s</small>' : '—';
  $('l-lo').textContent = minZ.toFixed(1);
  $('l-hi').textContent = maxZ.toFixed(1);
}

// ============================ DRIVE =================================
let curNodes=null, curPts=null, curParsed=null;
function note(msg, warn){ const n=document.getElementById('note');
  n.textContent=msg; n.className='note'+(warn?' warn':''); }

function render(text, keepView){
  const parsed=parseNMEA(text);
  if(parsed.pts.length<3){ note('Found '+parsed.pts.length+' usable fixes — need ≥3 GGA with altitude.', true); return; }
  const {nodes}=toLocal(parsed.pts);
  curNodes=nodes; curPts=parsed.pts; curParsed=parsed;
  if(!buildTerrain(nodes, keepView)) return;
  updateStats(parsed.pts, nodes, parsed);
  document.getElementById('stats').style.display='grid';
  document.getElementById('ctrls').style.display='flex';
  note('Surface built from '+nodes.length+' nodes · '+triangulate(nodes).length+' triangles.');
}
function rebuild(){ if(curNodes){ buildTerrain(curNodes, true); } }

document.getElementById('render').onclick=()=>{
  const t=document.getElementById('nmea').value.trim();
  if(!t){ note('Paste NMEA sentences first, or load the sample.', true); return; }
  render(t);
};

// ---- sample: synthesize a 100×100 m serpentine survey as GGA ----
function gga(lat,lon,alt,sec){
  const la=Math.abs(lat), ladeg=Math.floor(la), lam=((la-ladeg)*60).toFixed(5).padStart(8,'0');
  const lo=Math.abs(lon), lodeg=Math.floor(lo), lom=((lo-lodeg)*60).toFixed(5).padStart(8,'0');
  const hh=String(Math.floor(sec/3600)%24).padStart(2,'0');
  const mm=String(Math.floor(sec/60)%60).padStart(2,'0');
  const ssf=(sec%60).toFixed(2).padStart(5,'0');
  let body='GPGGA,'+hh+mm+ssf+','+String(ladeg).padStart(2,'0')+lam+','+(lat<0?'S':'N')+','
    +String(lodeg).padStart(3,'0')+lom+','+(lon<0?'W':'E')+',1,08,0.9,'+alt.toFixed(1)+',M,45.0,M,,';
  let cs=0; for(const ch of body) cs^=ch.charCodeAt(0);
  return '$'+body+'*'+cs.toString(16).toUpperCase().padStart(2,'0');
}
function sample(){
  const lat0=44.4268, lon0=26.1025, base=80;
  const mLat=110540, mLon=111320*Math.cos(lat0*Math.PI/180);
  const elev=(x,y)=> base
    + 7.5*Math.exp(-(((x-32)**2+(y-66)**2)/(2*19*19)))
    + 4.2*Math.exp(-(((x-74)**2+(y-28)**2)/(2*15*15)))
    - 0.045*x + 0.02*y
    + (Math.sin(x*0.18)*Math.cos(y*0.21))*0.6;
  const lines=[]; let sec=12*3600+11*60, dir=1;
  for(let y=0; y<=100; y+=4){
    const xs=[]; for(let x=0;x<=100;x+=4) xs.push(x);
    if(dir<0) xs.reverse();
    for(const x of xs){
      const z=elev(x,y) + (Math.random()-0.5)*0.18; // GNSS alt noise
      const lat=lat0 + y/mLat, lon=lon0 + x/mLon;
      lines.push(gga(lat,lon,z,sec)); sec+=1;
    }
    dir*=-1;
  }
  return lines.join('\n');
}
document.getElementById('sample').onclick=()=>{
  const data=sample();
  document.getElementById('nmea').value=data;
  render(data);
};

// ============================ LIVE FEED (WebSocket) =================
let ws=null, liveLines=[], liveStarted=false, pending=false, lastBuild=0;
const dot=document.getElementById('dot'), connectBtn=document.getElementById('connect');

function scheduleBuild(){
  if(pending) return; pending=true;
  const wait=Math.max(0, 700-(performance.now()-lastBuild)); // throttle to ~1 rebuild/0.7s
  setTimeout(()=>{
    pending=false; lastBuild=performance.now();
    render(liveLines.join('\n'), liveStarted); // keep camera after first frame
    liveStarted=true;
  }, wait);
}
function onLine(line){
  line=line.trim(); if(!line.startsWith('$')) return;
  liveLines.push(line);
  if(liveLines.length>200000) liveLines.shift(); // safety cap
  if(liveLines.length>=3) scheduleBuild();
}
function disconnect(){
  if(ws){ ws.onclose=null; try{ws.close();}catch(e){} ws=null; }
  dot.className='dot'; connectBtn.textContent='Connect';
}
function connect(){
  const url=document.getElementById('wsurl').value.trim();
  disconnect(); liveStarted=false;
  note('Connecting to '+url+' …');
  try{ ws=new WebSocket(url); }
  catch(e){ note('Bad WebSocket URL.', true); dot.className='dot err'; return; }
  ws.onopen=()=>{ dot.className='dot on'; connectBtn.textContent='Disconnect';
    note('Live — streaming fixes from the bridge.'); };
  ws.onmessage=ev=>{
    // a message may hold one line or several (newline-separated)
    String(ev.data).split(/\r?\n/).forEach(onLine);
  };
  ws.onerror=()=>{ dot.className='dot err';
    note('Connection error — is the C++ bridge running on that address?', true); };
  ws.onclose=()=>{ if(ws){ dot.className='dot err';
    note('Disconnected from bridge.', true); } ws=null; connectBtn.textContent='Connect'; };
}
connectBtn.onclick=()=>{ if(ws) disconnect(); else connect(); };

