exagEl.oninput=()=>{ exag=+exagEl.value; document.getElementById('exag-v').textContent=exag+'×'; rebuild(); };
cintEl.oninput=()=>{ contourInt=+cintEl.value; document.getElementById('cint-v').textContent=contourInt+' m'; rebuild(); };
