// ============================ INPUT (orbit) =========================
const pointers=new Map(); let lastPinch=0; let mode='rotate';
renderer.domElement.addEventListener('contextmenu', e=>e.preventDefault());
renderer.domElement.addEventListener('pointerdown', e=>{
  renderer.domElement.setPointerCapture(e.pointerId);
  pointers.set(e.pointerId, {x:e.clientX, y:e.clientY});
  mode = (e.button===2 || e.shiftKey) ? 'pan' : 'rotate';
});
renderer.domElement.addEventListener('pointermove', e=>{
  if(!pointers.has(e.pointerId)) return;
  const prev=pointers.get(e.pointerId);
  const dx=e.clientX-prev.x, dy=e.clientY-prev.y;
  pointers.set(e.pointerId,{x:e.clientX,y:e.clientY});

  if(pointers.size>=2){ // pinch zoom
    const p=[...pointers.values()];
    const d=Math.hypot(p[0].x-p[1].x, p[0].y-p[1].y);
    if(lastPinch) orbit.radius=Math.max(5, orbit.radius*(1 - (d-lastPinch)*0.005));
    lastPinch=d; applyCam(); return;
  }
  if(mode==='pan'){
    const f=orbit.radius*0.0018;
    const right=new THREE.Vector3(Math.sin(orbit.theta-Math.PI/2),Math.cos(orbit.theta-Math.PI/2)*-1,0).multiplyScalar(0);
    // pan in screen plane: compute camera basis
    const fwd=new THREE.Vector3().subVectors(orbit.target,camera.position).normalize();
    const rgt=new THREE.Vector3().crossVectors(fwd,camera.up).normalize();
    const up=new THREE.Vector3().crossVectors(rgt,fwd).normalize();
    orbit.target.addScaledVector(rgt, -dx*f).addScaledVector(up, dy*f);
  } else {
    orbit.theta -= dx*0.006;
    orbit.phi   -= dy*0.006;
    orbit.phi = Math.max(0.08, Math.min(Math.PI-0.08, orbit.phi));
  }
  applyCam();
});
function up(e){ pointers.delete(e.pointerId); if(pointers.size<2) lastPinch=0; }
renderer.domElement.addEventListener('pointerup', up);
renderer.domElement.addEventListener('pointercancel', up);
renderer.domElement.addEventListener('wheel', e=>{
  e.preventDefault();
  orbit.radius=Math.max(5, Math.min(50000, orbit.radius*(1+Math.sign(e.deltaY)*0.08)));
  applyCam();
},{passive:false});

addEventListener('resize', ()=>{
  camera.aspect=innerWidth/innerHeight; camera.updateProjectionMatrix();
  renderer.setSize(innerWidth,innerHeight);
});

// ============================ LOOP =================================
const rose=document.getElementById('rose'), azEl=document.getElementById('az');
function loop(){
  requestAnimationFrame(loop);
  if(flags.spin){ orbit.theta+=0.0026; applyCam(); }
  // compass: azimuth of camera about Z, 0 = looking North(+Y)
  let az=((-orbit.theta - Math.PI/2)*180/Math.PI)%360; if(az<0) az+=360;
  rose.setAttribute('transform','rotate('+(-az)+' 39 39)');
  azEl.textContent=Math.round(az)+'°';
  renderer.render(scene,camera);
}
applyCam(); loop();

